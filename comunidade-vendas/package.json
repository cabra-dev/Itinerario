{
  "name": "comunidade-vendas",
  "private": true,
  "version": "0.0.0",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "dist-app": "electron-builder"
  },
  "build": {
    "appId": "com.comunidade.gestor",
    "productName": "Comunidade Gestor",
    "publish": {
  "provider": "github",
  "owner": "cabra-dev",
  "repo": "Itinerario"
  },
    "files": [
      "dist/**/*",
      "electron.cjs"
    ],
    "extraResources": [
      {
        "from": "backend/dist/main.exe",
        "to": "backend/dist/main.exe"
      },
      {
        "from": "backend/.env",
        "to": "backend/dist/.env"
      },
      {
        "from": "prisma-engines",
        "to": "prisma-engines"
      },

      {
        "from": "backend/dist/query-engine-windows.exe",
        "to": "backend/dist/query-engine-windows.exe"
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "axios": "^1.16.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  }
}